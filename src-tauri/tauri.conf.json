{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "CloudSaw",
  "version": "2026.5.0",
  "identifier": "com.cloudsaw.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CloudSaw",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage", "rpm", "app", "dmg"],
    "category": "DeveloperTool",
    "copyright": "Copyright 2026 CloudSaw Contributors",
    "shortDescription": "Local-first AWS security scanner",
    "longDescription": "CloudSaw is a fully local-first desktop application that scans AWS environments for security misconfigurations. All data stays on your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "tf-modules/scanner-role/versions.tf": "tf-modules/scanner-role/versions.tf",
      "tf-modules/scanner-role/variables.tf": "tf-modules/scanner-role/variables.tf",
      "tf-modules/scanner-role/main.tf": "tf-modules/scanner-role/main.tf",
      "tf-modules/scanner-role/outputs.tf": "tf-modules/scanner-role/outputs.tf",
      "tf-modules/scanner-role/README.md": "tf-modules/scanner-role/README.md"
    }
  }
}
